# ClinixDev / Vetflow — copy to .env.local and fill in values

# ── Required (production) ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_MODE=false

# ── Optional: email (Resend) ───────────────────────────────────────
RESEND_API_KEY=
CLINIXDEV_SALES_EMAIL=

# ── Optional: AI (inventory OCR, AI assistant, social captions) ──
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── Optional: Stripe billing ───────────────────────────────────────
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_GROWTH=

# ── Meta social publishing (Facebook + Instagram OAuth) ────────────
# Create app at https://developers.facebook.com
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/social/meta/callback
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/api/social/meta/callback
# Random secret, min 16 characters — encrypts stored Page tokens
SOCIAL_TOKEN_ENCRYPTION_KEY=
